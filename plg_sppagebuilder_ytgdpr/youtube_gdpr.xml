<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="sppagebuilder" method="upgrade">
    <name>PLG_SPPAGEBUILDER_YOUTUBE_GDPR</name>
    <author>Dominik Henneke</author>
    <authorUrl>https://github.com/dhenneke/joomla-plugins</authorUrl>
    <copyright>(C) 2026 Dominik Henneke</copyright>
    <creationDate>May 2026</creationDate>
    <license>GNU/GPLv3 http://www.gnu.org/licenses/gpl-3.0.html</license>
    <version>1.0.2</version>
    <description>PLG_SPPAGEBUILDER_YOUTUBE_GDPR_XML_DESCRIPTION</description>
    <files>
        <filename plugin="youtube_gdpr">youtube_gdpr.php</filename>
        <folder>addons</folder>
        <folder>language</folder>
        <folder>layouts</folder>
    </files>
    <media destination="plg_sppagebuilder_youtube_gdpr">
        <folder>assets</folder>
    </media>
    <languages folder="language">
        <language tag="en-GB">en-GB/en-GB.plg_sppagebuilder_youtube_gdpr.ini</language>
        <language tag="en-GB">en-GB/en-GB.plg_sppagebuilder_youtube_gdpr.sys.ini</language>
        <language tag="de-DE">de-DE/de-DE.plg_sppagebuilder_youtube_gdpr.ini</language>
        <language tag="de-DE">de-DE/de-DE.plg_sppagebuilder_youtube_gdpr.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field name="cache_duration" type="number" default="3600"
                    label="PLG_SPPAGEBUILDER_YOUTUBE_GDPR_CACHE_DURATION_LABEL"
                    description="PLG_SPPAGEBUILDER_YOUTUBE_GDPR_CACHE_DURATION_DESC" />
            </fieldset>
        </fields>
    </config>
</extension>
