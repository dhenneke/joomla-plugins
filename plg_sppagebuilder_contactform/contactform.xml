<?xml version="1.0" encoding="UTF-8"?>
<extension type="plugin" group="sppagebuilder" method="upgrade">
    <name>PLG_SPPAGEBUILDER_CONTACTFORM</name>
    <author>Dominik Henneke</author>
    <authorUrl>https://github.com/dhenneke/joomla-plugins</authorUrl>
    <copyright>(C) 2026 Dominik Henneke</copyright>
    <creationDate>May 2026</creationDate>
    <license>GNU/GPLv3 http://www.gnu.org/licenses/gpl-3.0.html</license>
    <version>1.0.1</version>
    <description>PLG_SPPAGEBUILDER_CONTACTFORM_XML_DESCRIPTION</description>

    <files>
        <filename plugin="contactform">contactform.php</filename>
        <folder>addons</folder>
        <folder>language</folder>
        <folder>layouts</folder>
    </files>

    <media destination="plg_sppagebuilder_contactform">
        <folder>assets</folder>
    </media>

    <languages folder="language">
        <language tag="en-GB">en-GB/en-GB.plg_sppagebuilder_contactform.ini</language>
        <language tag="en-GB">en-GB/en-GB.plg_sppagebuilder_contactform.sys.ini</language>
        <language tag="de-DE">de-DE/de-DE.plg_sppagebuilder_contactform.ini</language>
        <language tag="de-DE">de-DE/de-DE.plg_sppagebuilder_contactform.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="recipient_email"
                    type="email"
                    required="false"
                    label="PLG_SPPAGEBUILDER_CONTACTFORM_RECIPIENT_EMAIL_LABEL"
                    description="PLG_SPPAGEBUILDER_CONTACTFORM_RECIPIENT_EMAIL_DESC" />
            </fieldset>
        </fields>
    </config>
</extension>
